NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=

# Neon Postgres / Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# AI and source storage
GEMINI_API_KEY=
# Optional: when set, Gemini calls use Gemini Enterprise Agent Platform through the global Vertex endpoint, and this key takes precedence over GEMINI_API_KEY.
GEMINI_ENTERPRISE_AGENT_KEY_PLATFORM_KEY=
GEMINI_MODEL=gemini-3.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AWS_REGION=us-east-1
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Background jobs
INNGEST_APP_ID=learnrecur-dev
INNGEST_DEV=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Set to 1 locally or in CI when you want to enforce production env readiness.
LEARNRECUR_STRICT_ENV=

# Email reminders
RESEND_API_KEY=
RESEND_FROM_EMAIL=
