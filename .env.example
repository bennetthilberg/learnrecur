NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=

# Neon Postgres / Prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# AI and source storage
GEMINI_API_KEY=
# Optional: when set, Gemini calls use Gemini Enterprise Agent Platform through the global Vertex endpoint, and this key takes precedence over GEMINI_API_KEY.
GEMINI_ENTERPRISE_AGENT_KEY_PLATFORM_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# auto preserves enterprise precedence and falls back to the Developer API only
# when the enterprise endpoint reports that the embedding model is unavailable.
GEMINI_EMBEDDING_API_MODE=auto
# Optional direct multimodal fallback through Meta's Model API.
META_API_KEY=
META_MUSE_MODEL=muse-spark-1.1
META_MUSE_BASE_URL=https://api.meta.ai/v1
AWS_REGION=us-east-1
S3_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Background jobs
INNGEST_APP_ID=learnrecur-dev
INNGEST_DEV=
# Production callback origin. Local dev always registers NEXT_PUBLIC_APP_URL instead.
INNGEST_SERVE_ORIGIN=
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Set to 1 locally or in CI when you want to enforce production env readiness.
LEARNRECUR_STRICT_ENV=

# Email reminders
RESEND_API_KEY=
RESEND_FROM_EMAIL=
