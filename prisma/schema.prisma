generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CollectionStatus {
  ACTIVE
  ARCHIVED
}

enum SourceFileKind {
  IMAGE
  PDF
  TEXT
  URL
  OTHER
}

enum SourceFileStatus {
  DRAFT
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum StudyMaterialKind {
  PDF
  WEB
}

enum StudyMaterialStatus {
  ACTIVE
  ARCHIVED
  DELETING
}

enum MaterialRevisionStatus {
  PENDING_UPLOAD
  QUEUED
  PROCESSING
  READY
  FAILED
  DELETING
}

enum MaterialCleanupStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum MaterialPageTextStatus {
  NEEDS_OCR
  OCR_PROCESSING
  OCR_READY
  OCR_FAILED
}

enum SkillDraftBatchStatus {
  PLANNING
  NEEDS_SCOPE
  PLANNED
  GENERATING
  READY
  PARTIAL
  FAILED
  ACTIVATING
  COMPLETE
}

enum SkillDraftBatchItemStatus {
  PLANNED
  GENERATING
  READY
  FAILED
  EXCLUDED
  ACTIVATING
  ACTIVE
}

enum SkillStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SkillFsrsState {
  NEW
  LEARNING
  REVIEW
  RELEARNING
}

enum ExerciseType {
  MULTIPLE_CHOICE
  EXACT_INPUT
}

enum AnswerKind {
  CHOICE
  TEXT
  NUMERIC
  MATH
}

enum ExerciseVerificationStatus {
  DRAFT
  UNVERIFIED
  VERIFIED
  REJECTED
}

enum ExerciseAttemptResult {
  CORRECT
  INCORRECT
  SKIPPED
}

enum FsrsRating {
  AGAIN
  HARD
  GOOD
  EASY
}

enum ExerciseRetirementReason {
  FLAGGED_INCORRECT
  FLAGGED_UNCLEAR
  FLAGGED_UNFAIR
  STALE
  DUPLICATE
  REPLACED
  MANUAL
  OTHER
}

enum ExerciseFlagReason {
  INCORRECT_ANSWER
  UNCLEAR_PROMPT
  UNFAIR
  STALE
  NOT_USEFUL
  OFF_TOPIC
  OTHER
}

enum ExerciseFlagStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum GenerationJobKind {
  SKILL_ACTIVATION
  CHOICE_EXERCISE_GENERATION
  EXACT_INPUT_EXERCISE_GENERATION
  MATH_EXERCISE_GENERATION
}

enum GenerationJobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum ReminderSendStatus {
  PENDING
  SKIPPED
  SENT
  FAILED
}

model User {
  id         String    @id
  email      String?
  name       String?
  imageUrl   String?
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  collections          Collection[]
  sourceFiles          SourceFile[]
  studyMaterials       StudyMaterial[]
  materialRevisions    MaterialRevision[]
  materialSections     MaterialSection[]
  materialChunks       MaterialChunk[]
  materialPages        MaterialPage[]
  materialCleanupJobs  MaterialCleanupJob[]
  skillDraftBatches    SkillDraftBatch[]
  skillDraftBatchItems SkillDraftBatchItem[]
  skills               Skill[]
  skillSourceRefs      SkillSourceRef[]
  exercises            Exercise[]
  exerciseAttempts     ExerciseAttempt[]
  reviewLogs           ReviewLog[]
  exerciseFlags        ExerciseFlag[]
  generationJobs       GenerationJob[]
  reminderPreference   ReminderPreference?
  reminderSendLogs     ReminderSendLog[]

  @@map("users")
}

model Collection {
  id          String           @id @default(cuid())
  userId      String
  name        String
  description String?
  status      CollectionStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills         Skill[]
  sourceFiles    SourceFile[]
  studyMaterials StudyMaterial[]

  @@unique([id, userId])
  @@index([userId, status])
  @@map("collections")
}

model SourceFile {
  id                 String           @id @default(cuid())
  userId             String
  collectionId       String?
  materialRevisionId String?
  kind               SourceFileKind   @default(OTHER)
  status             SourceFileStatus @default(DRAFT)
  originalName       String
  mimeType           String?
  byteSize           Int?
  storageBucket      String?
  storageKey         String?
  publicUrl          String?
  extractedText      String?
  metadata           Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection       Collection?       @relation(fields: [collectionId, userId], references: [id, userId], onDelete: NoAction)
  materialRevision MaterialRevision? @relation(fields: [materialRevisionId, userId], references: [id, userId], onDelete: Cascade)
  skillRefs        SkillSourceRef[]
  materialChunks   MaterialChunk[]

  @@unique([id, userId])
  @@unique([id, materialRevisionId, userId])
  @@index([userId, status])
  @@index([collectionId])
  @@index([materialRevisionId])
  @@map("source_files")
}

model StudyMaterial {
  id                  String              @id @default(cuid())
  userId              String
  collectionId        String?
  title               String
  kind                StudyMaterialKind
  status              StudyMaterialStatus @default(ACTIVE)
  activeRevisionId    String?             @unique
  deletionRequestedAt DateTime?
  lastUsedAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection     Collection?         @relation(fields: [collectionId, userId], references: [id, userId], onDelete: NoAction)
  activeRevision MaterialRevision?   @relation("ActiveMaterialRevision", fields: [activeRevisionId], references: [id], onDelete: SetNull)
  revisions      MaterialRevision[]  @relation("MaterialRevisions")
  cleanupJob     MaterialCleanupJob?

  @@unique([id, userId])
  @@index([userId, status, updatedAt])
  @@index([collectionId])
  @@map("study_materials")
}

model MaterialRevision {
  id                 String                 @id @default(cuid())
  userId             String
  materialId         String
  revisionNumber     Int
  status             MaterialRevisionStatus @default(PENDING_UPLOAD)
  sourceUrl          String?
  contentHash        String?
  byteSize           Int?
  pageCount          Int?
  fetchedPageCount   Int?
  storageBucket      String?
  storageKey         String?
  processingMetadata Json?
  errorCode          String?
  errorMessage       String?
  finalizedAt        DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  material          StudyMaterial     @relation("MaterialRevisions", fields: [materialId, userId], references: [id, userId], onDelete: Cascade)
  activeForMaterial StudyMaterial?    @relation("ActiveMaterialRevision")
  sourceFiles       SourceFile[]
  sections          MaterialSection[]
  chunks            MaterialChunk[]
  pages             MaterialPage[]
  draftBatches      SkillDraftBatch[]

  @@unique([id, userId])
  @@unique([materialId, revisionNumber])
  @@index([userId, status])
  @@map("material_revisions")
}

model MaterialSection {
  id                 String   @id @default(cuid())
  userId             String
  materialRevisionId String
  parentId           String?
  ordinal            Int
  level              Int      @default(1)
  title              String
  normalizedTitle    String
  pageStart          Int?
  pageEnd            Int?
  url                String?
  anchor             String?
  headingPath        String[]
  metadata           Json?
  createdAt          DateTime @default(now())

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  materialRevision MaterialRevision @relation(fields: [materialRevisionId, userId], references: [id, userId], onDelete: Cascade)
  parent           MaterialSection? @relation("MaterialSectionHierarchy", fields: [parentId, materialRevisionId, userId], references: [id, materialRevisionId, userId], onDelete: NoAction)
  children         MaterialSection[] @relation("MaterialSectionHierarchy")
  chunks           MaterialChunk[]

  @@unique([id, userId])
  @@unique([id, materialRevisionId, userId])
  @@unique([materialRevisionId, ordinal])
  @@index([materialRevisionId, parentId, ordinal])
  @@index([userId])
  @@map("material_sections")
}

model MaterialChunk {
  id                 String                   @id @default(cuid())
  userId             String
  materialRevisionId String
  materialSectionId  String?
  sourceFileId       String?
  ordinal            Int
  text               String
  tokenEstimate      Int
  contentHash        String
  locator            Json
  headingText        String?
  searchText         Unsupported("tsvector")? @default(dbgenerated("to_tsvector('simple'::regconfig, ((COALESCE(\"headingText\", ''::text) || ' '::text) || text))"))
  embedding          Unsupported("vector(768)")?
  createdAt          DateTime                 @default(now())

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  materialRevision MaterialRevision @relation(fields: [materialRevisionId, userId], references: [id, userId], onDelete: Cascade)
  materialSection  MaterialSection? @relation(fields: [materialSectionId, materialRevisionId, userId], references: [id, materialRevisionId, userId], onDelete: NoAction)
  sourceFile       SourceFile?      @relation(fields: [sourceFileId, materialRevisionId, userId], references: [id, materialRevisionId, userId], onDelete: NoAction)

  @@unique([id, userId])
  @@unique([materialRevisionId, ordinal])
  @@index([materialRevisionId, materialSectionId, ordinal])
  @@index([userId])
  @@index([searchText], type: Gin)
  @@map("material_chunks")
}

model MaterialPage {
  id                 String                 @id @default(cuid())
  userId             String
  materialRevisionId String
  pageNumber         Int
  embeddedText       String?
  ocrText            String?
  textStatus         MaterialPageTextStatus @default(NEEDS_OCR)
  contentHash        String
  tokenEstimate      Int                    @default(0)
  metadata           Json?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  materialRevision MaterialRevision @relation(fields: [materialRevisionId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([id, userId])
  @@unique([materialRevisionId, pageNumber])
  @@index([userId, textStatus])
  @@map("material_pages")
}

model MaterialCleanupJob {
  id           String                @id @default(cuid())
  userId       String
  materialId   String                @unique
  status       MaterialCleanupStatus @default(PENDING)
  attemptCount Int                   @default(0)
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  material StudyMaterial @relation(fields: [materialId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([materialId, userId])
  @@index([userId, status])
  @@map("material_cleanup_jobs")
}

model Skill {
  id                  String         @id @default(cuid())
  userId              String
  collectionId        String?
  title               String
  objective           String?
  rules               Json?
  examples            Json?
  exerciseConstraints Json?
  tags                String[]
  status              SkillStatus    @default(DRAFT)
  dueAt               DateTime?
  stability           Float?
  difficulty          Float?
  elapsedDays         Int            @default(0)
  scheduledDays       Int            @default(0)
  learningSteps       Int            @default(0)
  repetitions         Int            @default(0)
  lapses              Int            @default(0)
  fsrsState           SkillFsrsState @default(NEW)
  lastReviewedAt      DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  collection      Collection?           @relation(fields: [collectionId, userId], references: [id, userId], onDelete: NoAction)
  sourceRefs      SkillSourceRef[]
  exercises       Exercise[]
  attempts        ExerciseAttempt[]
  reviewLogs      ReviewLog[]
  generationJobs  GenerationJob[]
  draftBatchItems SkillDraftBatchItem[]

  @@unique([id, userId])
  @@index([userId, status, dueAt])
  @@index([collectionId])
  @@map("skills")
}

model SkillDraftBatch {
  id                 String                @id @default(cuid())
  userId             String
  materialRevisionId String
  instruction        String
  confirmedPlan      Json?
  status             SkillDraftBatchStatus @default(PLANNING)
  idempotencyKey     String
  requestedCount     Int                   @default(0)
  readyCount         Int                   @default(0)
  failedCount        Int                   @default(0)
  excludedCount      Int                   @default(0)
  activatedCount     Int                   @default(0)
  errorCode          String?
  errorMessage       String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  confirmedAt        DateTime?
  completedAt        DateTime?

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  materialRevision MaterialRevision      @relation(fields: [materialRevisionId, userId], references: [id, userId], onDelete: Cascade)
  items            SkillDraftBatchItem[]

  @@unique([id, userId])
  @@unique([userId, idempotencyKey])
  @@index([userId, status, createdAt])
  @@index([materialRevisionId])
  @@map("skill_draft_batches")
}

model SkillDraftBatchItem {
  id                 String                    @id @default(cuid())
  userId             String
  batchId            String
  skillId            String?
  ordinal            Int
  targetKey          String
  proposedTitle      String
  proposedObjective  String
  locator            Json
  status             SkillDraftBatchItemStatus @default(PLANNED)
  overlapSkillId     String?
  errorCode          String?
  errorMessage       String?
  generationAttempts Int                       @default(0)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch SkillDraftBatch @relation(fields: [batchId, userId], references: [id, userId], onDelete: Cascade)
  skill Skill?          @relation(fields: [skillId], references: [id], onDelete: SetNull)

  @@unique([id, userId])
  @@unique([batchId, ordinal])
  @@unique([batchId, targetKey])
  @@index([userId, status])
  @@index([skillId])
  @@map("skill_draft_batch_items")
}

model SkillSourceRef {
  id           String   @id @default(cuid())
  userId       String
  skillId      String
  sourceFileId String
  locator      Json?
  note         String?
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill      Skill      @relation(fields: [skillId, userId], references: [id, userId], onDelete: Cascade)
  sourceFile SourceFile @relation(fields: [sourceFileId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([skillId, sourceFileId])
  @@index([userId])
  @@index([sourceFileId])
  @@map("skill_source_refs")
}

model Exercise {
  id                   String                     @id @default(cuid())
  userId               String
  skillId              String
  type                 ExerciseType
  answerKind           AnswerKind
  prompt               String
  choices              Json?
  answerSpec           Json
  correctAnswerDisplay String
  explanation          String?
  difficulty           Int?
  expectedSeconds      Int?
  verificationStatus   ExerciseVerificationStatus @default(UNVERIFIED)
  retiredAt            DateTime?
  retirementReason     ExerciseRetirementReason?
  freshnessKey         String?
  sourceRefs           Json?
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill    Skill             @relation(fields: [skillId, userId], references: [id, userId], onDelete: Cascade)
  attempts ExerciseAttempt[]
  flags    ExerciseFlag[]

  @@unique([id, userId])
  @@unique([id, skillId, userId])
  @@index([userId, createdAt])
  @@index([skillId, verificationStatus])
  @@index([skillId, verificationStatus, retiredAt])
  @@map("exercises")
}

model ExerciseAttempt {
  id               String                @id @default(cuid())
  userId           String
  skillId          String
  exerciseId       String
  answer           Json
  normalizedAnswer String?
  isCorrect        Boolean
  result           ExerciseAttemptResult
  responseMs       Int?
  proposedRating   FsrsRating?
  finalRating      FsrsRating?
  feedbackShownAt  DateTime?
  createdAt        DateTime              @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill      @relation(fields: [skillId, userId], references: [id, userId], onDelete: Cascade)
  exercise  Exercise   @relation(fields: [exerciseId, skillId, userId], references: [id, skillId, userId], onDelete: Cascade)
  reviewLog ReviewLog?

  @@unique([id, userId])
  @@unique([id, skillId, userId])
  @@index([userId, createdAt])
  @@index([skillId, createdAt])
  @@index([exerciseId])
  @@map("exercise_attempts")
}

model ReviewLog {
  id                    String          @id @default(cuid())
  userId                String
  skillId               String
  exerciseAttemptId     String          @unique
  finalRating           FsrsRating
  reviewedAt            DateTime        @default(now())
  previousDueAt         DateTime?
  nextDueAt             DateTime?
  previousStability     Float?
  nextStability         Float?
  previousDifficulty    Float?
  nextDifficulty        Float?
  previousElapsedDays   Int?
  nextElapsedDays       Int?
  previousScheduledDays Int?
  nextScheduledDays     Int?
  previousLearningSteps Int?
  nextLearningSteps     Int?
  previousRepetitions   Int?
  nextRepetitions       Int?
  previousLapses        Int?
  nextLapses            Int?
  previousState         SkillFsrsState?
  nextState             SkillFsrsState?
  schedulerName         String
  schedulerVersion      String
  desiredRetention      Float
  schedulerParameters   Json
  createdAt             DateTime        @default(now())

  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill           Skill           @relation(fields: [skillId, userId], references: [id, userId], onDelete: Cascade)
  exerciseAttempt ExerciseAttempt @relation(fields: [exerciseAttemptId, skillId, userId], references: [id, skillId, userId], onDelete: Cascade)

  @@unique([exerciseAttemptId, skillId, userId])
  @@index([userId, reviewedAt])
  @@index([skillId, reviewedAt])
  @@map("review_logs")
}

model ExerciseFlag {
  id                String                    @id @default(cuid())
  userId            String
  exerciseId        String
  reason            ExerciseFlagReason
  note              String?
  status            ExerciseFlagStatus        @default(OPEN)
  resolvedAt        DateTime?
  resolutionNote    String?
  retiredExerciseAt DateTime?
  retirementReason  ExerciseRetirementReason?
  createdAt         DateTime                  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId, userId], references: [id, userId], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([exerciseId, status])
  @@map("exercise_flags")
}

model GenerationJob {
  id             String              @id @default(cuid())
  userId         String
  skillId        String
  kind           GenerationJobKind
  status         GenerationJobStatus @default(PENDING)
  provider       String
  model          String
  promptVersion  String
  requestedCount Int
  acceptedCount  Int                 @default(0)
  rejectedCount  Int                 @default(0)
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId, userId], references: [id, userId], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([skillId, status])
  @@map("generation_jobs")
}

model ReminderPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  enabled         Boolean  @default(false)
  email           String
  localHour       Int      @default(9)
  timezone        String   @default("America/New_York")
  minimumDueCount Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([enabled, localHour])
  @@map("reminder_preferences")
}

model ReminderSendLog {
  id                String             @id @default(cuid())
  userId            String
  localDate         String
  status            ReminderSendStatus
  dueCount          Int
  email             String?
  provider          String?
  providerMessageId String?
  errorMessage      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, localDate])
  @@index([status, createdAt])
  @@map("reminder_send_logs")
}
